rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) && 
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256;
      }

      allow get: if isOwner(userId);
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // 2. Stripe Extension Collections (Products & Prices)
    match /products/{id} {
      allow read: if true;
      allow write: if false; // System only
      
      match /prices/{priceId} {
        allow read: if true;
        allow write: if false; // System only
      }
    }

    // 3. Customer & Subscriptions (Stripe Sync)
    match /customers/{uid} {
      allow read: if isOwner(uid);
      allow write: if false; // Managed by extension

      match /subscriptions/{id} {
        allow read: if isOwner(uid);
        allow write: if false; // Managed by extension
      }
      
      match /checkout_sessions/{id} {
        allow read, write: if isOwner(uid);
      }
    }

    // 4. Properties
    match /properties/{propertyId} {
      function isValidProperty(data) {
        return data.keys().hasAll(['address', 'ownerId']) &&
               data.address is string && data.address.size() <= 500 &&
               data.ownerId == request.auth.uid;
      }

      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidProperty(incoming());
      allow update: if isOwner(existing().ownerId) && 
                      isValidProperty(incoming()) &&
                      incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId);
    }

    // 5. Video Projects
    match /video_projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['propertyId', 'ownerId']) &&
               data.propertyId is string &&
               data.ownerId == request.auth.uid;
      }

      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isOwner(existing().ownerId);
      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if isOwner(existing().ownerId) && 
                      isValidProject(incoming()) &&
                      incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
