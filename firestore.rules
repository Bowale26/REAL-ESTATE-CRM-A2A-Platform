rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'trialStart', 'subscriptionStatus', 'plan', 'createdAt', 'updatedAt']) 
        && data.email is string && data.email.size() <= 256
        && data.subscriptionStatus in ['trialing', 'active', 'canceled', 'past_due', 'none']
        && data.plan in ['monthly', 'yearly', 'none'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      // Allow creation of profile on first login
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incomingData())
        && incomingData().subscriptionStatus == 'trialing'; // Default to trialing on create

      // Updates: Users can only update their own profile
      // subscriptionStatus and trialStart are managed by the server or initial creation
      allow update: if isOwner(userId)
        && isValidUser(incomingData())
        && incomingData().diff(existingData()).affectedKeys().hasOnly(['email', 'displayName', 'updatedAt']);
    }
  }
}
