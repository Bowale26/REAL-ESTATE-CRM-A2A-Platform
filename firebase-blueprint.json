{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile tracking trial and subscription status.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "trialStart": { "type": "string", "format": "date-time" },
        "stripeCustomerId": { "type": "string" },
        "stripeSubscriptionId": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["trialing", "active", "canceled", "past_due", "none"] },
        "currentPeriodEnd": { "type": "string", "format": "date-time" },
        "plan": { "type": "string", "enum": ["monthly", "yearly", "none"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "subscriptionStatus"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles tracked by Firebase Auth UID."
    }
  }
}
